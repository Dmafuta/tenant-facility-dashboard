# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill every value before deploying.
# These are the ONLY values required to start the application.
# All integration credentials (M-Pesa, SMS, email, etc.) are configured
# from the Settings page inside the dashboard.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Public URL of the frontend (used for CORS)
FRONTEND_URL=https://dashboard.greatwallgardens.estate

# Database
DB_USERNAME=postgres
DB_PASSWORD=CHANGE_ME_strong_db_password

# JWT secret — generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_run_openssl_rand_hex_32

# First admin account (created on first boot)
SEED_ADMIN_EMAIL=admin@greatwallgardens.estate
SEED_ADMIN_PASSWORD=CHANGE_ME_strong_admin_password

# Cloudflare Turnstile — protects the public /resident-verify page from bots
# Get your keys at: https://dash.cloudflare.com/ → Turnstile
# Leave blank to disable (dev/staging). Test keys: https://developers.cloudflare.com/turnstile/troubleshooting/testing/
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
